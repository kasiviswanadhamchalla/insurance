                "{{GATEWAY_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "1.8 Login as Auditor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"AUDITOR_TOKEN\", jsonData.data.token);",
                  "}"
                ],
                "type": "javascript"
