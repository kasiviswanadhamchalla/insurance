                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer_john\",\n  \"password\": \"password123\",\n  \"email\": \"john@example.com\",\n  \"fullName\": \"John Doe\",\n  \"roles\": [\"ROLE_USER\"]\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/auth/register",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
