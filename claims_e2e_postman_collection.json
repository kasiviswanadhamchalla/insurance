              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "1.4 Customer Login (First Step)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"JWT_TOKEN\", jsonData.data.token);",
                  "}",
                  "if (jsonData.data && jsonData.data.mfaTransactionId) {",
                  "    pm.collectionVariables.set(\"MFA_TRANSACTION_ID\", jsonData.data.mfaTransactionId);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer_john\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/auth/login",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "1.5 Setup MFA (Enable 2FA)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/auth/mfa/setup",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "auth",
                "mfa",
                "setup"
              ]
            }
          }
        },
        {
          "name": "1.6 Login Verify MFA (When enabled)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"JWT_TOKEN\", jsonData.data.token);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mfaTransactionId\": \"{{MFA_TRANSACTION_ID}}\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/auth/login/mfa/verify",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "auth",
                "login",
                "mfa",
                "verify"
              ]
            }
          }
        },
        {
          "name": "1.7 Login as Processor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
