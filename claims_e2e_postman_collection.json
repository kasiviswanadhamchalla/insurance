    {
      "name": "2. Claim & Documents (Customer Flow)",
      "item": [
        {
          "name": "2.1 Create Draft Claim",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set(\"CLAIM_ID\", jsonData.data.id);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL-100256\",\n  \"claimAmount\": 1500.00,\n  \"lossType\": \"ACCIDENT\",\n  \"dateOfOccurrence\": \"2026-07-01T10:00:00Z\",\n  \"description\": \"Car scraped a guardrail near city center.\"\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/claims",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "claims"
              ]
            }
          }
        },
        {
          "name": "2.2 Upload Supporting Document (Receipt)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set(\"DOCUMENT_ID\", jsonData.data.id);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "text",
                  "value": "Dummy file content representing receipt photo."
                },
                {
                  "key": "category",
                  "value": "receipt",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/claims/{{CLAIM_ID}}/documents",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "claims",
                "{{CLAIM_ID}}",
                "documents"
              ]
            }
          }
        },
        {
          "name": "2.3 List Claim Documents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/claims/{{CLAIM_ID}}/documents",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "claims",
                "{{CLAIM_ID}}",
                "documents"
              ]
            }
          }
        },
        {
          "name": "2.4 Download Claim Document",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/documents/{{DOCUMENT_ID}}/download",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "documents",
                "{{DOCUMENT_ID}}",
                "download"
              ]
            }
          }
        },
        {
          "name": "2.5 Submit Claim (Locks Claim & Triggers Flow)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/claims/{{CLAIM_ID}}/submit",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "claims",
                "{{CLAIM_ID}}",
                "submit"
              ]
            }
          }
        },
        {
          "name": "2.6 Fetch Customer Self Claims List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/claims?page=0&size=10",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "claims"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Fraud Reporting",
      "item": [
        {
          "name": "3.1 Get Automated Fraud Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{PROCESSOR_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/fraud/reports/{{CLAIM_ID}}",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "fraud",
                "reports",
                "{{CLAIM_ID}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Task Management (Processor Flow)",
      "item": [
        {
          "name": "4.1 Get Pending Tasks Queue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.content && jsonData.data.content.length > 0) {",
                  "    pm.collectionVariables.set(\"TASK_ID\", jsonData.data.content[0].id);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{PROCESSOR_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/tasks/pending?page=0&size=10",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "tasks",
                "pending"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "4.2 Claim Task in Queue",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{PROCESSOR_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/tasks/{{TASK_ID}}/claim",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "tasks",
                "{{TASK_ID}}",
                "claim"
              ]
            }
          }
        },
        {
          "name": "4.3 Complete Task Action (Approve / Reject)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{PROCESSOR_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actionDecision\": \"APPROVE\",\n  \"comment\": \"Documentation is complete, risk check passed.\"\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/tasks/{{TASK_ID}}/action",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "tasks",
                "{{TASK_ID}}",
                "action"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Compliance & Audit",
      "item": [
        {
          "name": "5.1 Search Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{AUDITOR_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/audit/logs?claimId={{CLAIM_ID}}&page=0&size=10",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "audit",
                "logs"
              ],
              "query": [
                {
                  "key": "claimId",
                  "value": "{{CLAIM_ID}}"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "5.2 Export Audit CSV Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{AUDITOR_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{GATEWAY_URL}}/audit/reports/export?format=csv",
              "host": [
                "{{GATEWAY_URL}}"
              ],
              "path": [
                "audit",
                "reports",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "csv"
                }
              ]
            }
          }
        }
      ]
    }
