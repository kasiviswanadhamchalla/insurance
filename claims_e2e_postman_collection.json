              "raw": "{\n  \"username\": \"processor_jane\",\n  \"password\": \"password123\",\n  \"email\": \"jane@example.com\",\n  \"fullName\": \"Jane Smith\",\n  \"roles\": [\"ROLE_PROCESSOR\"]\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/auth/register",
