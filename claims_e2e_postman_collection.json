                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"auditor_alan\",\n  \"password\": \"password123\",\n  \"email\": \"alan@example.com\",\n  \"fullName\": \"Alan Auditor\",\n  \"roles\": [\"ROLE_AUDITOR\"]\n}"
            },
            "url": {
              "raw": "{{GATEWAY_URL}}/auth/register",
              "host": [
